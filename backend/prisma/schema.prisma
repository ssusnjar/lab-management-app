generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Nalog {
  id                Int      @id @default(autoincrement())
  brojRadnogNaloga String
  narucitelj       String
  gradiliste       String
  datum            DateTime

  uzorci Uzorak[]
}

model Uzorak {
  id                     Int    @id @default(autoincrement())
  laboratorijskaOznaka  String @unique
  lokacija              String

  nalogId Int
  nalog   Nalog @relation(fields: [nalogId], references: [id])
}